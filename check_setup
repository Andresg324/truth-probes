#Extract activation for one statement
def get_activation(statement, layer = 13):
    tokens = model.to_tokens(statement)
    with torch.no_grad():
        _, cache = model.run_with_cache(tokens)
    return cache["resid_post", layer][0,-1].cpu().numpy()


# collect activations for all statements
y = np.array([d["label"] for d in data])

CACHE_FILE = f"results/activations_{model_name}.npy"

if os.path.exists(CACHE_FILE):
    print("Loading cached activations...")
    all_activations = np.load(CACHE_FILE)
else:
    print("Extracting activations (will cache after this run)...")
    all_activations = []
    for d in data:
        tokens = model.to_tokens(d["statement"])
        with torch.no_grad():
            _, cache = model.run_with_cache(tokens)
        layer_acts = np.array([
            cache["resid_post", L][0, -1].cpu().numpy()
            for L in range(model.cfg.n_layers)
        ])
        all_activations.append(layer_acts)
    all_activations = np.array(all_activations)
    np.save(CACHE_FILE, all_activations)
    print(f"Cached -> {CACHE_FILE}")
print(f"Activations shape: {all_activations.shape}")

results = []
for L in range(model.cfg.n_layers): # Goes through all of the layers
    X_layer = all_activations[:, L, :]
    Xtr_1, Xte_1, ytr_1, yte_1 = train_test_split(
        X_layer, y, test_size=0.2, random_state=0, stratify=y
    )
    probe_1 = LogisticRegression(max_iter=2000, C=0.1).fit(Xtr_1, ytr_1)
    acc = probe_1.score(Xte_1, yte_1)
    results.append((L,acc))
    print(f"Layer {L}/{model.cfg.n_layers - 1}", end="\r")

