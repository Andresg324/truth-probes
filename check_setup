#Finds the numerical score for a sentence's likelihood to be accurate, closer to zero is more accurate
def sentence_logprob(model, sentence):
    tokens = model.to_tokens(sentence)
    with torch.no_grad():
        logits = model(tokens)
    log_probs = torch.log_softmax(logits[0], dim=1)
    actual_tokens = tokens[0, 1:]
    predicted_at = log_probs[:-1]
    return predicted_at[range(len(actual_tokens)), actual_tokens].sum().item()

print("Paris (true):", sentence_logprob(model, "The Eiffel Tower is in Paris"))
print("Rome (false):", sentence_logprob(model, "The Eiffel Tower is in Rome"))

import json
