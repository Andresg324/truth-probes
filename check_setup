from sklearn.linear_model import LogisticRegression

BEST_LAYER = 19
domains = ["geography", "science", "history", "math"]
results = {}

for test_domain in domains:
    #Split by domain
    train_idx = [i for i, d in enumerate(data) if d["domain"] != test_domain]
    test_idx  = [i for i, d in enumerate(data) if d["domain"] == test_domain]

    Xtr = all_activations[train_idx, BEST_LAYER, :]
