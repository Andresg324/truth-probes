    yte = np.array([data[i]["label"] for i in test_idx])

    probe = LogisticRegression(max_iter=2000, C=0.1).fit(Xtr, ytr)
    train_acc = probe.score(Xtr, ytr)
    test_acc = probe.score(Xte, yte)

    results[test_domain] = test_acc
    print(f"Train: all except {test_domain:12s} | "
          f"Test: {test_domain:12s} | "
          f"Train acc: {train_acc:.3f} | Test acc: {test_acc:.3f}")
    
    print("\nMean cross-domain accuracy:", round(sum(results.values()) / len(results), 3))
